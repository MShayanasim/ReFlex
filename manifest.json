{
  "key": "",
  "manifest_version": 3,
  "name": "ReFlex",
  "version": "1.2.3",
  "minimum_chrome_version": "109",
  "description": "Redesigns the FAST-NUCES Flex portal with a premium dashboard, dark mode, GPA projections, and live grade change tracking.",
  "permissions": ["storage", "activeTab", "identity", "background", "alarms", "offscreen"],
  "host_permissions": ["*://flexstudent.nu.edu.pk/*"],
  "oauth2": {
    "client_id": "650320840540-bjo54gekj5o1m0s5cmekiq6c86op2f5e.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/userinfo.email"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ReFlex Settings"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://flexstudent.nu.edu.pk/*"],
      "css": ["styles.css"],
      "js": ["ff-observer.js", "ff-attendance.js", "runMarks.js", "runTranscript.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "reflex-icon-16.png",
    "24": "reflex-icon-24.png",
    "48": "reflex-icon-48.png",
    "128": "reflex-icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*", "reflex-icon-24.png", "reflex-icon-16.png", "recaptcha-themer.js"],
      "matches": ["*://flexstudent.nu.edu.pk/*"]
    }
  ]
}
